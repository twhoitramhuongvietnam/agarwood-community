{
  "name": "agarwood-community",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:analyze": "powershell -Command \"$env:ANALYZE='true'; prisma generate; next build\"",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:migrate:supabase": "powershell -Command \"$env:MIGRATE_TARGET='supabase'; npx prisma migrate deploy\"",
    "db:push:supabase": "powershell -Command \"$env:MIGRATE_TARGET='supabase'; npx prisma db push\"",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:backup": "npx tsx scripts/backup-supabase-to-local.ts",
    "db:restore-public": "npx tsx scripts/restore-backup-to-public.ts",
    "cloudinary:sweep": "npx tsx scripts/sweep-cloudinary-orphans.ts",
    "cloudinary:sweep:execute": "npx tsx scripts/sweep-cloudinary-orphans.ts --execute",
    "postinstall": "prisma generate"
  },
  "dependencies": {

// ============================================================
// Agarwood Community Platform — Prisma Schema
// Database: PostgreSQL (Supabase)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  GUEST
  VIP
  ADMIN
  INFINITE // Hạng đặc biệt — full quyền VIP Vàng + quyền admin, cấp thủ công
}

enum AccountType {
  BUSINESS // doanh nghiệp — có company, SP, chứng nhận
  INDIVIDUAL // cá nhân/chuyên gia — chỉ feed, hồ sơ, tài liệu
}

// Phân hạng hội viên theo Điều lệ Hội (Chương II, Điều 7)
enum MemberCategory {
  OFFICIAL // Hội viên chính thức — đầy đủ quyền biểu quyết, ứng cử, bầu cử
  AFFILIATE // Hội viên liên kết — DN không đủ tiêu chuẩn chính thức, hoặc DN FDI
  HONORARY // Hội viên danh dự — cá nhân/tổ chức uy tín, có đóng góp cho Hội
}

// Trạng thái đơn xin kết nạp Hội viên (Điều lệ Hội, Điều 11)
enum ApplicationStatus {
  PENDING // đã nộp, chờ Ban Thường vụ xét duyệt
  APPROVED // Chủ tịch đã ký quyết định công nhận
  REJECTED // bị từ chối
}

// Phân loại bài viết trong News
/// LEGAL — văn bản pháp lý (Chính sách bảo mật, Điều khoản sử dụng, ...).
/// 2 slug đặc biệt `chinh-sach-bao-mat` → /privacy, `dieu-khoan-su-dung` → /terms.
/// Các LEGAL khác redirect về /phap-ly (hub văn bản pháp quy).
///
/// SPONSORED_PRODUCT — bài sản phẩm admin viết theo yêu cầu KH (có trả phí).
/// Khác với PostCategory.PRODUCT (bài VIP tự đăng). Hiển thị chung trang /tin-tuc
/// với GENERAL và section "Tin Hội" trên homepage.
enum NewsCategory {
  GENERAL // Tin tức ngành — hiển thị ở /tin-tuc
  RESEARCH // Nghiên cứu khoa học, báo cáo học thuật — hiển thị ở /nghien-cuu
  LEGAL // Văn bản pháp lý — /privacy, /terms hoặc /phap-ly
  SPONSORED_PRODUCT // Bài sản phẩm trả phí — legacy, giữ cho data cũ
  // Phase 3 (2026-04): tin riêng cho doanh nghiệp/sản phẩm. Khác với
  // SPONSORED_PRODUCT (legacy) — categories mới link rõ tới Company/Product.
  BUSINESS // Tin doanh nghiệp — link tới Company qua relatedCompanyId
  PRODUCT // Tin sản phẩm — link tới Product (+ Company) qua relatedProductId
  // Phase 3.5 (2026-04): admin curate tin báo chí ngoài + tin khuyến nông.
  EXTERNAL_NEWS // Tin báo chí ngoài (curated) — hiển thị ở /tin-bao-chi, có sourceName + sourceUrl
  AGRICULTURE // Tin khuyến nông — hiển thị ở /khuyen-nong
}

/// Template hiển thị bài tin — quyết định cách render content + cách bài
/// xuất hiện ở /multimedia. Chỉ áp với News (không liên quan Post feed).
enum NewsTemplate {
  NORMAL // Bài bình thường — text + ảnh + video chèn lẫn (RichTextEditor)
  PHOTO // Tin ảnh — bulk gallery, mỗi ảnh có caption. Cũng hiện ở /multimedia
  VIDEO // Tin video — bulk URL YouTube, mỗi video có caption. /multimedia
}

/// Phân loại đối tác / cơ quan đoàn thể liên kết — dùng cho marquee trang chủ.
enum PartnerCategory {
  GOVERNMENT // Cơ quan quản lý nhà nước (Bộ, Sở, Cục, Tổng cục…)
  ASSOCIATION // Hiệp hội, hội nghề nghiệp
  RESEARCH // Viện, trường, đơn vị nghiên cứu
  ENTERPRISE // Doanh nghiệp đối tác chiến lược
  INTERNATIONAL // Tổ chức quốc tế
  MEDIA // Cơ quan báo chí, đài phát thanh – truyền hình
  OTHER // Khác
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  PENDING_PAYMENT
}

enum PostStatus {
  PENDING // chờ admin kiểm duyệt — chỉ owner thấy, người khác 404
  PUBLISHED // đã duyệt, mọi người thấy
  LOCKED // bị lock do report vi phạm HOẶC admin reject khi duyệt
  DELETED
}

enum PostCategory {
  GENERAL // bài viết chung — mặc định, hiển thị ở /feed
  NEWS // tin tức của doanh nghiệp — section "Tin doanh nghiệp" trang chủ
  PRODUCT // tin sản phẩm (giới thiệu / vừa được chứng nhận) — section "Tin sản phẩm" trang chủ
}

enum PromotionRequestStatus {
  PENDING // chờ admin duyệt
  APPROVED // admin duyệt → bài được đẩy lên trang chủ (isPromoted=true)
  REJECTED // admin từ chối (kèm lý do ở reviewNote)
  CANCELLED // owner tự rút trước khi admin xử lý
}

/// Các ban/ủy ban nội bộ Hội — mỗi VIP có thể thuộc nhiều ban, mỗi ban
/// map sang 1 tập Permission trong `lib/permissions.ts`. Thêm ban mới:
/// (1) thêm value vào enum này, (2) thêm entry COMMITTEE_PERMS trong
/// permissions.ts, (3) migration ALTER TYPE ADD VALUE.
enum Committee {
  THUONG_VU // Ban Thường vụ — duyệt hội viên, quyết định quan trọng
  CHAP_HANH // Ban Chấp hành — truy cập đọc admin
  KIEM_TRA // Ban Kiểm tra — xác nhận thanh toán, giám sát
  THAM_DINH // Ban Thẩm định — review chứng nhận (thay isCouncilMember)
  THU_KY // Ban Thư ký — đăng tin tức, duyệt feed, văn bản pháp lý
  TRUYEN_THONG // Ban Truyền thông — tin tức (có publish), promote bài
}

enum ReportStatus {
  PENDING // chờ admin xử lý
  REVIEWED // đã xem xét, giữ bài
  DISMISSED // bác report
  ACTIONED // đã lock bài
}

enum CertStatus {
  DRAFT // hội viên đang điền form
  PENDING // đã nộp, chờ xét duyệt
  UNDER_REVIEW // admin đang xét duyệt
  APPROVED // được cấp badge
  REJECTED // từ chối
  REFUNDED // đã hoàn tiền
}

enum ReviewMode {
  ONLINE // sản phẩm nhỏ, giá trị thấp — 2% giá bán, clamp [1tr, 20tr]
  OFFLINE // thẩm định tại chỗ — flat 200tr, all-inclusive
}

enum ReviewVote {
  PENDING // chưa vote
  APPROVE // đồng ý
  REJECT // phủ quyết — 1 REJECT khiến toàn bộ đơn bị auto reject
}

enum MediaOrderStatus {
  NEW // vừa đặt hàng
  CONFIRMED // admin đã xác nhận
  IN_PROGRESS // đang thực hiện
  DELIVERED // đã bàn giao bài viết
  REVISION // khách yêu cầu chỉnh sửa
  COMPLETED // hoàn tất, đã thanh toán
  CANCELLED
}

enum MediaServiceType {
  ARTICLE_COMPANY // viết bài giới thiệu doanh nghiệp
  ARTICLE_PRODUCT // viết bài giới thiệu sản phẩm
  PRESS_RELEASE // thông cáo báo chí
  SOCIAL_CONTENT // nội dung mạng xã hội
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentType {
  MEMBERSHIP_FEE // phí hội viên hàng năm
  CERTIFICATION_FEE // phí xét duyệt chứng nhận SP
  MEDIA_SERVICE // phí dịch vụ truyền thông
  BANNER_FEE // [Phase 6] phí đăng ký / gia hạn banner quảng cáo
}

enum BannerStatus {
  PENDING_PAYMENT // user vừa tạo, chờ chuyển khoản
  PENDING_APPROVAL // user đã CK, chờ admin duyệt content
  ACTIVE // admin đã duyệt, đang chạy
  REJECTED // admin từ chối content
  EXPIRED // hết hạn (cron daily check)
}

// Phase 4 (2026-04-29): banner gắn với (page, vùng) thay vì global position.
// Tách per-section: tin-tuc/nghien-cuu/khuyen-nong/tin-bao-chi không share slot.
// Trang chủ tách _LEFT/_RIGHT cho top + 2 sidebar riêng RESEARCH/MULTIMEDIA.
enum BannerSlot {
  // Trang chủ — top split 2 banner trái/phải (mỗi banner 485×90, tổng 970×90)
  HOMEPAGE_TOP_LEFT
  HOMEPAGE_TOP_RIGHT
  HOMEPAGE_MID
  // Trang chủ — 2 sidebar riêng cho 2 section khác nhau
  HOMEPAGE_RESEARCH_SIDEBAR
  HOMEPAGE_MULTIMEDIA_SIDEBAR

  // Tin tức (chuyên mục NEWS)
  NEWS_LIST_SIDEBAR
  NEWS_DETAIL_SIDEBAR

  // Nghiên cứu (RESEARCH)
  RESEARCH_LIST_SIDEBAR
  RESEARCH_DETAIL_SIDEBAR

  // Khuyến nông (AGRICULTURE)
  AGRICULTURE_LIST_SIDEBAR
  AGRICULTURE_DETAIL_SIDEBAR

  // Tin báo chí (PRESS / EXTERNAL)
  PRESS_LIST_SIDEBAR
  PRESS_DETAIL_SIDEBAR

  // Multimedia + Feed (MXH)
  MULTIMEDIA_DETAIL_SIDEBAR
  FEED_SIDEBAR
}

// Danh mục đóng góp phi tài chính — admin ghi nhận để thăng hạng hội viên
enum HonoraryCategory {
  RESEARCH // Nghiên cứu khoa học, báo cáo học thuật
  LOGISTICS // Hậu cần sự kiện, tổ chức hoạt động
  EXTERNAL_RELATIONS // Đối ngoại, kết nối đối tác
  OTHER // Khác
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  emailVerified  DateTime?
  name           String
  phone          String?
  avatarUrl      String?
  passwordHash   String? // null cho OAuth users
  role           Role           @default(GUEST)
  accountType    AccountType    @default(BUSINESS)
  memberCategory MemberCategory @default(OFFICIAL) // Điều lệ Hội, Chương II

  // Membership & ranking
  contributionTotal Int @default(0) // tổng phí membership tích lũy (VND)
  displayPriority   Int @default(0) // thứ tự ưu tiên hiển thị bài — tính từ contributionTotal
  reputationScore   Int @default(100) // điểm uy tín — future use, schema sẵn sàng

  // Giới thiệu bản thân / tiểu sử — hiển thị trên trang hồ sơ cá nhân
  bio    String? @db.Text
  bio_en String? @db.Text
  bio_zh String? @db.Text
  bio_ar String? @db.Text

  // Refund info — dùng khi hoàn phí chứng nhận bị từ chối
  bankAccountName   String?
  bankAccountNumber String?
  bankName          String?

  membershipExpires DateTime?
  isActive          Boolean   @default(true)

  // Hội đồng thẩm định (HDTD) — admin toggle để cấp quyền thẩm định chứng nhận SP
  isCouncilMember Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts                     Account[]
  sessions                     Session[]
  memberships                  Membership[]
  leaderPositions              Leader[]
  company                      Company?
  products                     Product[]               @relation("ProductOwner")
  productRevisions             ProductRevision[]       @relation("ProductRevisionEditor")
  // Phase 3.6 (2026-04): audit history Post (admin + owner edits).
  postRevisions                PostRevision[]          @relation("PostRevisionEditor")
  posts                        Post[]
  reports                      Report[]                @relation("ReporterRelation")
  certifications               Certification[]
  mediaOrders                  MediaOrder[]
  payments                     Payment[]
  postReactions                PostReaction[]
  comments                     Comment[]
  commentLikes                 CommentLike[]
  banners                      Banner[]
  applications                 MembershipApplication[] @relation("ApplicantRelation")
  applicationsReviewed         MembershipApplication[] @relation("ReviewerRelation")
  surveyResponses              SurveyResponse[]
  consultationRequests         ConsultationRequest[]   @relation("ConsultationRequester")
  consultationsHandled         ConsultationRequest[]   @relation("ConsultationHandler")
  contactMessagesHandled       ContactMessage[]        @relation("ContactHandler")
  honoraryContributions        HonoraryContribution[]  @relation("HonoraryRecipient")
  honoraryContributionsCreated HonoraryContribution[]  @relation("HonoraryCreatedBy")
  councilReviews               CertificationReview[]
  promotionRequestsMade        PostPromotionRequest[]  @relation("PromotionRequester")
  promotionRequestsReviewed    PostPromotionRequest[]  @relation("PromotionReviewer")
  committeeMemberships         CommitteeMembership[]   @relation("CommitteeMember")
  committeeAssignmentsMade     CommitteeMembership[]   @relation("CommitteeAssignedBy")
  ledgerTransactionsRecorded   LedgerTransaction[]     @relation("LedgerTransactionRecorder")

  @@index([role])
  @@index([accountType])
  @@index([contributionTotal])
  @@index([displayPriority])
  @@index([isCouncilMember])
  @@map("users")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// MEMBERSHIP & PAYMENT
// ============================================================

model Membership {
  id         String           @id @default(cuid())
  userId     String
  amountPaid Int // VND
  validFrom  DateTime
  validTo    DateTime
  status     MembershipStatus @default(ACTIVE)
  paymentRef String? // mã giao dịch PayOS
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment?

  @@index([userId])
  @@index([status])
  @@index([validTo])
  @@map("memberships")
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  type           PaymentType
  status         PaymentStatus @default(PENDING)
  amount         Int // VND
  payosOrderCode String?       @unique // mã đơn hàng PayOS
  payosTransId   String? // mã giao dịch PayOS sau khi thành công
  description    String?
  failureReason  String?

  // Polymorphic reference — chỉ 1 trong 4 field này có giá trị
  membershipId    String? @unique
  certificationId String? @unique
  mediaOrderId    String? @unique
  bannerId        String? // KHÔNG unique — 1 banner có thể có nhiều payment (đăng ký + nhiều lần gia hạn)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  membership        Membership?        @relation(fields: [membershipId], references: [id])
  certification     Certification?     @relation(fields: [certificationId], references: [id])
  mediaOrder        MediaOrder?        @relation(fields: [mediaOrderId], references: [id])
  banner            Banner?            @relation(fields: [bannerId], references: [id])
  // Sổ quỹ — auto-tạo khi admin xác nhận CK; 1-1 qua relatedPaymentId @unique.
  ledgerTransaction LedgerTransaction?

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([payosOrderCode])
  @@index([createdAt])
  @@index([bannerId])
  @@map("payments")
}

// Đóng góp phi tài chính — admin ghi nhận để thăng hạng hội viên
// mà không cần chuyển khoản (NCKH, hậu cần sự kiện, đối ngoại...)
model HonoraryContribution {
  id               String           @id @default(cuid())
  userId           String // hội viên được ghi nhận
  creditAmount     Int // số tiền quy đổi (VND) — cộng vào contributionTotal
  reason           String           @db.Text
  category         HonoraryCategory
  extendMonths     Int              @default(12) // số tháng gia hạn membershipExpires
  createdByAdminId String // admin nào tạo record này

  createdAt DateTime @default(now())

  user      User @relation("HonoraryRecipient", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User @relation("HonoraryCreatedBy", fields: [createdByAdminId], references: [id])

  @@index([userId])
  @@index([createdByAdminId])
  @@index([createdAt])
  @@map("honorary_contributions")
}

// ============================================================
// COMPANY & PRODUCTS
// ============================================================

model Company {
  id              String  @id @default(cuid())
  ownerId         String  @unique // 1 VIP = 1 company
  name            String
  name_en         String?
  name_zh         String?
  name_ar         String?
  slug            String  @unique // dùng cho URL: /companies/[slug]
  description     String? @db.Text
  description_en  String? @db.Text
  description_zh  String? @db.Text
  description_ar  String? @db.Text
  logoUrl         String?
  coverImageUrl   String?
  website         String?
  phone           String?
  address         String?
  address_en      String?
  address_zh      String?
  address_ar      String?
  foundedYear     Int?
  employeeCount   String? // "1-10", "10-50", "50-200",...
  businessLicense String? // số ĐKKD

  // Người đại diện tổ chức — bắt buộc theo Điều lệ Hội, Điều 7 Khoản 2c
  representativeName        String?
  representativePosition    String?
  representativePosition_en String?
  representativePosition_zh String?
  representativePosition_ar String?

  isVerified  Boolean @default(false) // admin verify
  isPublished Boolean @default(true)

  // Featured (admin pin) — dùng cho landing page "Top doanh nghiệp tiêu biểu"
  isFeatured    Boolean @default(false)
  featuredOrder Int? // null = chưa pin, số nhỏ = ưu tiên cao

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products      Product[]
  galleryImages CompanyGalleryImage[]

  @@index([slug])
  @@index([isPublished])
  @@index([isFeatured, featuredOrder])
  @@map("companies")
}

/// Bộ sưu tập ảnh của doanh nghiệp — hiển thị ở tab "Bộ sưu tập" trên profile.
/// Owner (VIP) và ADMIN được phép upload/delete.
model CompanyGalleryImage {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  imageUrl  String // Cloudinary secure_url (folder "doanh-nghiep/MM-YYYY")
  caption   String? // chú thích ảnh — tuỳ chọn
  sortOrder Int     @default(0) // số nhỏ = hiển thị trước; fallback theo createdAt DESC

  createdAt DateTime @default(now())

  @@index([companyId, sortOrder])
  @@map("company_gallery_images")
}

model Product {
  id             String   @id @default(cuid())
  ownerId        String // userId — ai đăng sản phẩm
  companyId      String? // optional — chỉ có nếu owner có company (VIP)
  name           String
  name_en        String?
  name_zh        String?
  name_ar        String?
  slug           String   @unique
  description    String?  @db.Text
  description_en String?  @db.Text
  description_zh String?  @db.Text
  description_ar String?  @db.Text
  imageUrls      String[] // mảng URL ảnh sản phẩm (Cloudinary)
  category       String? // loại trầm: trầm tự nhiên, trầm nuôi cấy, tinh dầu,...
  category_en    String?
  category_zh    String?
  category_ar    String?
  priceRange     String? // "500k-1tr", "1tr-5tr",...
  isPublished    Boolean  @default(true)

  // Phase 4 (2026-04-29): KH yêu cầu spec sheet + variant để trang chi tiết
  // chuyên nghiệp hơn (KH ref Lazada). Tất cả nullable — chưa nhập thì ẩn.
  origin         String? // Xuất xứ vùng trồng (Khánh Hòa, Quảng Nam,...)
  treeAge        String? // Tuổi cây dó bầu ("10-15 năm", "trên 25 năm")
  packagingNote  String? @db.Text // Quy cách đóng gói (hộp/túi/giấy gói)
  scentProfile   String? @db.Text // Mùi hương profile (ngọt, gỗ, ấm,...)
  /// Mảng variant theo trọng lượng/kích cỡ — JSON shape:
  /// `[{ name: "50gr", priceRange: "500k-1tr" }, { name: "100gr", priceRange: "1-2tr" }]`
  /// Ẩn UI selector nếu null hoặc rỗng.
  variants       Json?
  // Phase 4 follow-up (2026-04-29): policy field cho trang chi tiết. Khi
  // tạo SP mới mà user bỏ trống → server tự điền default text từ
  // PRODUCT_DEFAULT_SHIPPING / PRODUCT_DEFAULT_RETURN.
  shippingPolicy String? @db.Text // Tuỳ chọn giao hàng
  returnPolicy   String? @db.Text // Đổi trả & Bảo hành

  // Certification
  certStatus     CertStatus @default(DRAFT)
  badgeUrl       String? // URL badge chứng nhận (Cloudinary)
  certAppliedAt  DateTime?
  certApprovedAt DateTime?
  certExpiredAt  DateTime? // badge có thể có hạn sử dụng — future use

  // Featured (admin pin) — dùng cho menu "Sản phẩm tiêu biểu" + landing page "Top SP hot trend"
  isFeatured    Boolean @default(false)
  featuredOrder Int? // null = chưa pin, số nhỏ = ưu tiên cao

  // Ranking — denormalized từ owner.displayPriority tại thời điểm đăng
  ownerPriority Int @default(0)

  // Liên kết với bài post trên feed (MXH Trầm Hương). 1-1 optional.
  // Khi Post bị xoá → cascade xoá Product (merge model: product luôn đi kèm 1 post).
  // Với product tạo trước khi gộp, cột này null cho đến khi backfill.
  postId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner          User              @relation("ProductOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  company        Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  post           Post?             @relation(fields: [postId], references: [id], onDelete: Cascade)
  certifications Certification[]
  comments       Comment[]
  revisions      ProductRevision[]

  @@index([ownerId])
  @@index([companyId])
  @@index([certStatus])
  @@index([slug])
  @@index([isFeatured, featuredOrder])
  @@index([ownerPriority])
  @@map("products")
}

/// Lịch sử chỉnh sửa Product. Snapshot full mỗi lần edit — v0 tại create,
/// vN tại mỗi lần update (owner hoặc admin). Dùng cho audit + diff UI.
/// Retention: cap 50 row/product (inline prune); có thể thêm time-based
/// sweep sau (vd >180d) qua cron.
/**
 * Phase 3.6 (2026-04): audit history cho Post.
 * Pattern song song với ProductRevision — snapshot mỗi lần admin/owner save,
 * track ai sửa + field nào đổi để render diff. Owner có thể so sánh giữa bản
 * cuối của admin vs bản cuối của mình. Schema rất gọn: Post chỉ có 3 field
 * editable (title, content, imageUrls).
 */
model PostRevision {
  id      String @id @default(cuid())
  postId  String
  version Int // auto-increment per post

  // Snapshot các field editable (mirror Post)
  title     String?
  content   String   @db.Text
  imageUrls String[]

  // Audit meta
  /// ID user đã sửa (owner hoặc admin)
  editedBy      String
  /// "OWNER" | "ADMIN" — phân biệt owner self-edit vs admin moderation edit
  editedRole    String
  editedAt      DateTime @default(now())
  /// Lý do — bắt buộc khi admin edit, optional khi owner edit
  reason        String?
  /// Tên field đã đổi so với revision trước (vd ["content", "title"])
  changedFields String[]

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  editor User @relation("PostRevisionEditor", fields: [editedBy], references: [id])

  @@unique([postId, version])
  @@index([postId, editedAt])
  @@index([postId, editedRole, version])
  @@map("post_revisions")
}

model ProductRevision {
  id        String @id @default(cuid())
  productId String
  version   Int // auto-increment per product

  // Snapshot các field có thể sửa (mirror Product) — dùng để diff
  name           String
  name_en        String?
  name_zh        String?
  name_ar        String?
  slug           String
  description    String?  @db.Text
  description_en String?  @db.Text
  description_zh String?  @db.Text
  description_ar String?  @db.Text
  category       String?
  category_en    String?
  category_zh    String?
  category_ar    String?
  priceRange     String?
  imageUrls      String[]
  isPublished    Boolean

  // Audit meta
  /// ID user đã sửa (owner hoặc admin/TRUYEN_THONG)
  editedBy      String
  /// "OWNER" | "ADMIN" | "TRUYEN_THONG" — giúp UI hiển thị vai trò mà
  /// không phải join bảng permission mỗi lần
  editedRole    String
  editedAt      DateTime @default(now())
  /// Lý do chỉnh sửa — bắt buộc khi admin edit (không phải owner)
  reason        String?
  /// Tên field đã đổi so với revision trước — phục vụ quick preview
  /// (vd "name, imageUrls"). Null ở v0.
  changedFields String[]

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  editor  User    @relation("ProductRevisionEditor", fields: [editedBy], references: [id])

  @@unique([productId, version])
  @@index([productId, editedAt])
  @@map("product_revisions")
}

// ============================================================
// CERTIFICATION
// ============================================================

model Certification {
  id          String     @id @default(cuid())
  productId   String
  applicantId String // userId của hội viên nộp đơn
  status      CertStatus @default(PENDING)

  // Thông tin hồ sơ
  documentUrls  String[] // tài liệu đính kèm (Cloudinary)
  applicantNote String?  @db.Text
  reviewNote    String?  @db.Text // ghi chú của admin khi duyệt/từ chối

  // Thanh toán & hoàn tiền — lưu trực tiếp VND (không *100)
  feePaid           Int // phí đã tính theo reviewMode + productSalePrice
  refundBankName    String?
  refundAccountName String?
  refundAccountNo   String?
  refundedAt        DateTime?
  refundNote        String?

  // Xét duyệt
  reviewedBy String? // adminId (legacy — Sprint 2 sẽ thay bằng CertificationReview)
  reviewedAt DateTime?
  approvedAt DateTime?
  rejectedAt DateTime?

  // Process type
  reviewMode       ReviewMode @default(ONLINE)
  productSalePrice BigInt? // snapshot giá bán lúc nộp đơn — chỉ bắt buộc khi reviewMode=ONLINE (dùng để tính phí 2%)
  certCode         String?    @unique // HTHVN-YYYY-NNNN — set khi APPROVED, dùng cho /verify

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product               @relation(fields: [productId], references: [id])
  applicant User                  @relation(fields: [applicantId], references: [id])
  payment   Payment?
  reviews   CertificationReview[]

  @@index([productId])
  @@index([applicantId])
  @@index([status])
  @@map("certifications")
}

// Vote record của 1 thành viên hội đồng thẩm định (HDTD) trên 1 đơn chứng nhận.
// Luôn có đúng 5 record cho 1 Certification đã được admin chỉ định hội đồng.
model CertificationReview {
  id              String     @id @default(cuid())
  certificationId String
  reviewerId      String
  vote            ReviewVote @default(PENDING)
  comment         String?    @db.Text // bắt buộc khi vote != PENDING (validate ở API)
  votedAt         DateTime?
  createdAt       DateTime   @default(now())

  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  reviewer      User          @relation(fields: [reviewerId], references: [id])

  @@unique([certificationId, reviewerId])
  @@index([reviewerId])
  @@index([certificationId])
  @@map("certification_reviews")
}

// ============================================================
// SOCIAL FEED — POSTS & INTERACTIONS
// ============================================================

model Post {
  id            String     @id @default(cuid())
  authorId      String
  title         String?
  content       String     @db.Text
  imageUrls     String[] // ảnh đính kèm (Cloudinary)
  // Phase 3.7 round 4 (2026-04): thumbnail 16:9 hiển thị trên homepage
  // section "Tin DN/SP mới nhất". Fallback nếu null: imageUrls[0] →
  // extract first image trong content → AgarwoodPlaceholder.
  coverImageUrl String?
  status        PostStatus @default(PENDING) // mới: mặc định chờ admin duyệt. Admin tạo thì code override sang PUBLISHED.

  // Moderation — lý do admin reject khi duyệt (khác với lockReason của
  // auto-lock từ report). Hiển thị cho owner ở trang bài viết để biết
  // cần sửa gì trước khi submit lại.
  moderationNote String?   @db.Text
  moderatedAt    DateTime?
  moderatedBy    String? // adminId

  // Loại bài — phân biệt tin tức DN / tin sản phẩm / bài thường
  category PostCategory @default(GENERAL)

  // Phase 3.7 round 4 (2026-04): Cross-classify Post → News list pages.
  // Admin tag bài feed chỉnh chu vào 1-3 NewsCategory để bài xuất hiện
  // thêm ở /tin-tuc, /nghien-cuu, /khuyen-nong, /tin-bao-chi tương ứng.
  // Empty = chỉ hiện ở /feed như cũ. Validation max 3 ở API layer.
  newsCategories NewsCategory[] @default([])

  // Visibility
  isPremium  Boolean @default(false) // true nếu author là VIP — set tự động
  isPromoted Boolean @default(false) // admin có thể pin bài lên top
  // Timestamp khi admin promote bài (set isPromoted=true HOẶC newsCategories
  // có phần tử). Cron `unpromote-stale` daily gỡ cả 2 cờ sau 2 ngày. Null =
  // chưa promote bao giờ. Backward-compat: bài có dữ liệu cũ chưa migrate
  // được backfill = ngày deploy.
  promotedAt DateTime?

  // Ranking — denormalized từ author.displayPriority tại thời điểm đăng
  // Cập nhật lại khi hội viên gia hạn membership
  authorPriority Int @default(0)

  // Engagement
  viewCount   Int @default(0)
  reportCount Int @default(0)

  // Lock info
  lockedAt   DateTime?
  lockedBy   String? // adminId
  lockReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author            User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  product           Product? // sidecar metadata khi category=PRODUCT
  reports           Report[]
  reactions         PostReaction[]
  tags              PostTag[]
  comments          Comment[]
  promotionRequests PostPromotionRequest[]
  // Phase 3.6 (2026-04): audit history các lần edit (admin + owner).
  revisions         PostRevision[]

  @@index([authorId])
  @@index([status])
  @@index([isPremium])
  @@index([authorPriority, createdAt])
  @@index([status, createdAt])
  @@index([isPromoted, authorPriority, createdAt]) // feed ORDER BY
  @@index([createdAt])
  @@index([category, createdAt]) // homepage queries: latest by category
  @@index([category, isPremium, authorPriority]) // homepage VIP-priority queries
  @@index([status, authorId]) // feed: owner's PENDING + everyone's PUBLISHED
  @@map("posts")
}

model PostReaction {
  id     String @id @default(cuid())
  postId String
  userId String
  type   String @default("LIKE") // LIKE, LOVE,... mở rộng sau

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId]) // 1 user chỉ react 1 lần / bài
  @@map("post_reactions")
}

// ============================================================
// POST PROMOTION REQUEST — owner xin admin đẩy bài lên trang chủ
// ============================================================
//
// Flow:
//   1. Owner click "Xin đẩy lên trang chủ" trên feed card → tạo row PENDING
//      (API: POST /api/posts/[id]/request-promotion, body: { reason })
//   2. Admin thấy trong inbox /admin/bai-viet/xin-dang
//   3. Admin APPROVE → Post.isPromoted = true + request.status = APPROVED
//      Admin REJECT  → request.status = REJECTED + reviewNote (lý do)
//   4. Owner thấy badge status trên card bài của mình
//
// Invariant: mỗi Post chỉ có 1 row PENDING tại 1 thời điểm — enforce ở
// app layer (API check trước khi create), vì Prisma không hỗ trợ partial
// unique index. Row cũ chuyển REJECTED/APPROVED/CANCELLED rồi mới cho phép
// tạo row PENDING mới.
//
// Admin CŨNG có cách chủ động — toggle isPromoted trực tiếp qua
// PATCH /api/admin/posts/[id]/promote (không cần qua request). Request chỉ
// là kênh "thụ động" khi owner muốn đề xuất.
model PostPromotionRequest {
  id          String  @id @default(cuid())
  postId      String
  requestedBy String
  reason      String? @db.Text // owner's ask — tại sao đáng đẩy

  status     PromotionRequestStatus @default(PENDING)
  reviewedBy String? // adminId xử lý
  reviewedAt DateTime?
  reviewNote String?                @db.Text // bắt buộc khi REJECT — lý do từ chối hiển thị cho owner

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  requester User  @relation("PromotionRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  reviewer  User? @relation("PromotionReviewer", fields: [reviewedBy], references: [id])

  @@index([postId])
  @@index([status, createdAt]) // admin inbox: WHERE status=PENDING ORDER BY createdAt DESC
  @@index([requestedBy])
  @@map("post_promotion_requests")
}

// ============================================================
// COMMITTEE MEMBERSHIP — phân bổ hội viên vào các ban Hội
// ============================================================
//
// Mỗi row = 1 user đang thuộc 1 ban cụ thể. 1 user có thể thuộc nhiều ban
// (nhiều row). Quyền hạn tương ứng của từng ban định nghĩa ở
// `lib/permissions.ts` → mapping `COMMITTEE_PERMS`.
//
// Field `position` để chứa vai trò nội bộ trong ban ("Trưởng ban",
// "Phó trưởng ban", "Thành viên"…) — admin nhập tay, không enum để
// tương thích với các danh xưng không đều. KHÔNG dùng để quyết định
// quyền hạn (quyền = hàm của committee type, không phải position).
//
// Migrate từ `User.isCouncilMember` cũ: true → 1 row
// (committee=THAM_DINH, position=null). Field cũ giữ lại 1 sprint để
// hỗ trợ rollback, sau đó drop.
model CommitteeMembership {
  id         String    @id @default(cuid())
  userId     String
  committee  Committee
  position   String? // "Trưởng ban", "Phó trưởng ban", "Thành viên"
  assignedAt DateTime  @default(now())
  assignedBy String? // adminId gán

  user           User  @relation("CommitteeMember", fields: [userId], references: [id], onDelete: Cascade)
  assignedByUser User? @relation("CommitteeAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, committee]) // mỗi user × committee = 1 row
  @@index([committee])
  @@index([userId])
  @@map("committee_memberships")
}

// ============================================================
// COMMENTS — polymorphic (Post + Product)
// ============================================================

model Comment {
  id       String @id @default(cuid())
  authorId String
  content  String @db.Text

  // Polymorphic target — exactly one of postId/productId/newsId must be set.
  // Phase 3.4 (2026-04): thêm newsId cho /tin-tuc + /nghien-cuu detail page.
  postId    String?
  productId String?
  newsId    String?

  // Reply — flat with mention (parentId = comment being replied to)
  parentId String?

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post    Post?         @relation(fields: [postId], references: [id], onDelete: Cascade)
  product Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  news    News?         @relation(fields: [newsId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId, createdAt])
  @@index([productId, createdAt])
  @@index([newsId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

model CommentLike {
  id        String @id @default(cuid())
  commentId String
  userId    String

  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId]) // 1 user chỉ like 1 lần / comment
  @@map("comment_likes")
}

model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String
  tagId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ============================================================
// REPORT & MODERATION
// ============================================================

model Report {
  id          String       @id @default(cuid())
  postId      String
  reporterId  String
  reason      String // "SPAM", "FAKE_INFO", "INAPPROPRIATE", "OTHER"
  description String?      @db.Text
  status      ReportStatus @default(PENDING)

  reviewedBy String? // adminId
  reviewedAt DateTime?
  adminNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User @relation("ReporterRelation", fields: [reporterId], references: [id])

  @@unique([postId, reporterId]) // 1 user chỉ report 1 lần / bài
  @@index([postId])
  @@index([status])
  @@map("reports")
}

// ============================================================
// NEWS & ANNOUNCEMENTS (Ban quản trị hội đăng)
// ============================================================

model News {
  id                  String         @id @default(cuid())
  title               String
  title_en            String?
  title_zh            String?
  title_ar            String?
  slug                String         @unique
  excerpt             String?
  excerpt_en          String?
  excerpt_zh          String?
  excerpt_ar          String?
  content             String         @db.Text
  content_en          String?        @db.Text
  content_zh          String?        @db.Text
  content_ar          String?        @db.Text
  coverImageUrl       String?
  category            NewsCategory   @default(GENERAL)
  // Phase 3.7 round 4 (2026-04): max 3 secondary categories cho phép 1 bài
  // xuất hiện ở nhiều list page (vd primary=BUSINESS + secondary=RESEARCH
  // → bài hiện ở cả /tin-tuc + /nghien-cuu). Homepage giữ primary-only filter.
  // Validation max 3 + exclude primary ở API layer.
  secondaryCategories NewsCategory[] @default([])
  // Phase 3.7 round 4 (2026-04): admin pin per-section trên trang chủ. Khác
  // `isPinned` boolean global (vẫn dùng cho NewsSection "Tin Hội" + sidebar
  // featured). pinnedInCategories=[BUSINESS,RESEARCH] → bài lên top section
  // homepage Tin DN + Nghiên cứu, kể cả khi primary là cái khác (mở rộng
  // visibility cross-list). Empty = không pin section nào.
  pinnedInCategories  NewsCategory[] @default([])
  template            NewsTemplate   @default(NORMAL)
  isPublished         Boolean        @default(false)
  isPinned            Boolean        @default(false)
  // Timestamp khi admin ghim bài. Cron `unpin-stale` daily check, gỡ ghim sau
  // 2 ngày. Null = bài chưa ghim hoặc đã ghim trước khi feature triển khai
  // (cron skip để không gỡ nhầm — admin quản lý tay những bài đó).
  pinnedAt            DateTime?
  publishedAt         DateTime?
  authorId            String // adminId

  // Phase 3 (2026-04) — links cho category BUSINESS/PRODUCT.
  // BUSINESS: chỉ relatedCompanyId. PRODUCT: cả relatedCompanyId +
  // relatedProductId. Validation enforce ở API; schema để optional cho
  // các category khác có thể bỏ trống.
  relatedCompanyId String?
  relatedProductId String?

  // Phase 3 — gallery cho template=PHOTO (array {url, caption}) hoặc
  // template=VIDEO (array {url, caption} với url là YouTube). NULL khi
  // template=NORMAL (RichTextEditor đã embed inline).
  // JSON shape: [{ "url": string, "caption": string }]
  gallery Json?

  // Import metadata — dùng khi crawl từ website cũ.
  // Phase 3.5 (2026-04): cũng dùng cho category=EXTERNAL_NEWS (admin curate
  // tin báo chí ngoài) — sourceName + sourceUrl bắt buộc cho EXTERNAL.
  sourceUrl      String? // URL gốc (crawl import hoặc EXTERNAL_NEWS source)
  sourceName     String? // Tên báo nguồn (vd "VnExpress", "Tuổi Trẻ") — chỉ dùng cho EXTERNAL_NEWS
  originalAuthor String? // Tên tác giả gốc (vd "Admin", "BBT") — hiển thị khi có, không thay authorId

  // SEO — per-locale overrides for <title>, meta description, image alt.
  // Fallback chain: localize() picks seoTitle_{locale} → siblings → seoTitle → title.
  seoTitle          String?
  seoTitle_en       String?
  seoTitle_zh       String?
  seoTitle_ar       String?
  seoDescription    String?
  seoDescription_en String?
  seoDescription_zh String?
  seoDescription_ar String?
  coverImageAlt     String?
  coverImageAlt_en  String?
  coverImageAlt_zh  String?
  coverImageAlt_ar  String?

  // SEO — single (VI source-of-truth). focusKeyword feeds the 19-point
  // scoring rubric. seoScore + seoScoreDetail are recomputed on save.
  focusKeyword      String?
  secondaryKeywords String[] @default([])
  seoScore          Int?
  seoScoreDetail    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 3.4 (2026-04): bình luận trên trang detail.
  comments Comment[]

  @@index([category, isPublished, publishedAt])
  @@index([isPublished, isPinned, publishedAt]) // homepage news carousel: WHERE isPublished ORDER BY isPinned, publishedAt
  @@index([slug])
  @@index([seoScore])
  // Phase 3: filter /multimedia + /tin-tuc theo template
  @@index([template, isPublished, publishedAt])
  @@map("news")
}

// ============================================================
// MEDIA SERVICE — DỊCH VỤ TRUYỀN THÔNG
// ============================================================

model MediaOrder {
  id             String  @id @default(cuid())
  requesterId    String? // userId đặt dịch vụ (null nếu là guest)
  requesterName  String // lưu lại tên lúc đặt
  requesterEmail String
  requesterPhone String

  serviceType MediaServiceType
  status      MediaOrderStatus @default(NEW)

  // Yêu cầu từ khách
  requirements   String    @db.Text
  targetKeywords String? // từ khóa SEO mong muốn
  referenceUrls  String[] // URL tham khảo
  deadline       DateTime? // deadline mong muốn của khách
  budget         String? // ngân sách dự kiến

  // Xử lý nội bộ
  assignedTo       String? // email/tên nhân sự phụ trách
  quotedPrice      Int? // giá báo (VND)
  internalNote     String?   @db.Text
  deliveryFileUrls String[] // URL file bài viết bàn giao (Cloudinary)
  deliveredAt      DateTime?
  completedAt      DateTime?
  cancelReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requester User?    @relation(fields: [requesterId], references: [id])
  payment   Payment?

  @@index([requesterId])
  @@index([status])
  @@index([serviceType])
  @@map("media_orders")
}

// ============================================================
// SITE CONFIG — cấu hình chung của website
// ============================================================

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique // "membership_fee_min", "membership_fee_max", "cert_fee",...
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_config")
}

// ============================================================
// MENU CMS — Navbar items, support 1 cấp submenu
// ============================================================

model MenuItem {
  id            String     @id @default(cuid())
  /// Slug ổn định dùng làm cầu nối giữa code và CMS.
  /// Route registry (lib/route-menu-map.ts) tham chiếu menuKey để xác định
  /// route nào thuộc menu nào → highlight nhất quán cho mọi page (kể cả deep).
  /// Có thể null cho menu mới chưa cần gắn route nào.
  menuKey       String?    @unique
  label         String
  label_en      String?
  label_zh      String?
  label_ar      String?
  href          String
  parentId      String?
  parent        MenuItem?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      MenuItem[] @relation("MenuTree")
  sortOrder     Int        @default(0)
  isVisible     Boolean    @default(true)
  isNew         Boolean    @default(false)
  comingSoon    Boolean    @default(false)
  openInNewTab  Boolean    @default(false)
  /// Các prefix route con — dùng để highlight menu cha khi user ở deep page.
  /// Vd: "/feed" có matchPrefixes = ["/feed", "/bai-viet"]. Empty = chỉ match đúng href.
  matchPrefixes String[]   @default([])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([parentId, sortOrder])
  @@map("menu_items")
}

// ============================================================
// HERO GALLERY — Ảnh nền trang chủ (Section "Tin Hội / Bản tin hội viên").
// Admin upload N ảnh, mỗi ngày chọn 1 ảnh ngẫu nhiên (deterministic theo
// date nên mọi user cùng ngày thấy cùng ảnh → CDN cache hiệu quả).
// ============================================================

model HeroImage {
  id        String   @id @default(cuid())
  imageUrl  String // Cloudinary secure_url (folder "gallery/MM-YYYY")
  label     String? // Ghi chú admin ("Rừng gió — tháng 11/2026")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("hero_images")
}

// ============================================================
// BANNER ADS — Phase 6
// ============================================================

model Banner {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Content
  imageUrl  String // Cloudinary URL
  targetUrl String // link tới DN/SP/bài post (mở tab mới khi click)
  title     String // tiêu đề ngắn (hiện tooltip + alt)
  // Phase 4.2 (2026-04-29): 1 banner có thể assign nhiều slot CÙNG SHAPE
  // (vd 1 ảnh portrait dùng cho cả NEWS_LIST_SIDEBAR + RESEARCH_LIST_SIDEBAR
  //  + ...). Validate same-shape ở admin form, không enforce ở DB.
  positions BannerSlot[] @default([HOMEPAGE_TOP_LEFT])

  // Schedule
  startDate DateTime // ngày bắt đầu hiển thị
  endDate   DateTime // ngày hết hạn (extend khi gia hạn)

  // Workflow
  status       BannerStatus @default(PENDING_PAYMENT)
  rejectReason String?      @db.Text // ghi chú khi admin từ chối
  approvedAt   DateTime?
  approvedBy   String? // adminId

  // Payment & pricing
  price Int // tổng tiền đăng ký lần đầu (VND) — không update khi gia hạn

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[] // 1 banner → nhiều payment (lần đầu + các lần gia hạn)

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@index([status, endDate]) // homepage query: ACTIVE + đang trong khoảng startDate-endDate
  // Phase 4.2 (2026-04-29): positions là array → composite B-tree index không
  // áp dụng được. Render query dùng `positions has slot` → cần GIN index trên
  // positions; viết bằng raw SQL trong migration (Prisma chưa hỗ trợ trực tiếp).
  @@map("banners")
}

// ============================================================
// PARTNERS — Đối tác / cơ quan đoàn thể liên kết với Hội
// ============================================================

model Partner {
  id          String          @id @default(cuid())
  name        String
  shortName   String? // viết tắt để hiển thị khi không có logo (initials fallback)
  category    PartnerCategory @default(OTHER)
  logoUrl     String? // Cloudinary — null = dùng initials placeholder
  websiteUrl  String? // link mở tab mới khi click; null = không clickable
  description String? // hiển thị tooltip / hover
  sortOrder   Int             @default(0) // số nhỏ = ưu tiên hiển thị trước
  isActive    Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([category])
  @@map("partners")
}

// ============================================================
// DOCUMENT MANAGEMENT — Công văn, tài liệu nội bộ
// ============================================================

enum DocumentCategory {
  CONG_VAN_DEN // công văn đến
  CONG_VAN_DI // công văn đi
  BIEN_BAN_HOP // biên bản họp
  QUYET_DINH // quyết định
  HOP_DONG // hợp đồng
  // ── Văn bản pháp quy (Public, hiển thị trên /phap-ly) ──
  DIEU_LE // Điều lệ Hội
  QUY_CHE // Quy chế nội bộ (VAWA)
  GIAY_PHEP // Giấy phép Đại hội
}

model Document {
  id             String           @id @default(cuid())
  title          String
  title_en       String?
  title_zh       String?
  title_ar       String?
  description    String?          @db.Text
  description_en String?          @db.Text
  description_zh String?          @db.Text
  description_ar String?          @db.Text
  category       DocumentCategory
  documentNumber String? // số hiệu công văn (vd: CV-2026-001, 56/QĐ-VAWA)
  issuedDate     DateTime? // ngày ban hành
  issuer         String? // cơ quan / người ban hành (vd: "Chủ tịch VAWA", "Bộ Nội vụ")
  issuer_en      String?
  issuer_zh      String?
  issuer_ar      String?
  sortOrder      Int              @default(0) // thứ tự hiển thị trên /phap-ly
  isPublic       Boolean          @default(false) // true = hiển thị trên /phap-ly (public)

  // Google Drive
  driveFileId      String @unique
  driveViewUrl     String
  driveDownloadUrl String
  fileName         String
  mimeType         String
  fileSize         Int // bytes

  // AI extracted content
  extractedText String? @db.Text
  summary       String? @db.Text
  summary_en    String? @db.Text
  summary_zh    String? @db.Text
  summary_ar    String? @db.Text

  // Metadata
  uploadedBy    String // adminId
  downloadCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isPublic])
  @@index([createdAt])
  @@index([isPublic, createdAt]) // BreakingTicker: isPublic=true AND createdAt >= 30d ago
  @@map("documents")
}


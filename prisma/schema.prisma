// ============================================================
// MEMBERSHIP APPLICATION — Đơn xin kết nạp Hội viên
// Theo Điều lệ Hội, Điều 11: BCH xét hồ sơ → Chủ tịch quyết định trong 30 ngày
// ============================================================

model MembershipApplication {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("ApplicantRelation", fields: [userId], references: [id], onDelete: Cascade)

  // Nội dung đơn
  requestedCategory      MemberCategory @default(OFFICIAL) // hạng hội viên xin kết nạp
  reason                 String         @db.Text // lý do xin gia nhập, giới thiệu bản thân / tổ chức
  representativeName     String? // với tổ chức
  representativePosition String? // với tổ chức

  // Xử lý
  status       ApplicationStatus @default(PENDING)
  submittedAt  DateTime          @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  reviewer     User?             @relation("ReviewerRelation", fields: [reviewedById], references: [id], onDelete: SetNull)
  rejectReason String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@map("membership_applications")
}

// ============================================================
// SURVEY SYSTEM — generic, dùng nhiều loại khảo sát
// ============================================================

enum SurveyAudience {
  ALL // mọi user (kể cả guest đã login)
  BUSINESS // chỉ accountType = BUSINESS
  INDIVIDUAL // chỉ accountType = INDIVIDUAL
  BOTH_VIP // cả BUSINESS + INDIVIDUAL (loại GUEST)
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ConsultationStatus {
  PENDING
  CONTACTED
  DONE
  CANCELLED
}

/**
 * Bộ khảo sát động — admin tạo qua UI. Câu hỏi lưu dạng JSON, có thể có
 * `mapsTo` để tự đồng bộ câu trả lời sang field User/Company tương ứng.
 * Cấu trúc 1 câu hỏi (trong `questions` JSON):
 * {
 * id: string,                    // unique trong scope survey
 * label: string,                 // câu hỏi hiển thị
 * type: "text"|"textarea"|"number"|"select"|"multiselect"|"scale",
 * options?: string[],            // cho select/multiselect
 * required?: boolean,
 * mapsTo?: "user.fieldName"|"company.fieldName",
 * scoreRule?: Record<string, number>,  // map giá trị → điểm cho recommendation
 * helpText?: string,
 * }
 */
model Survey {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  title_en       String?
  title_zh       String?
  title_ar       String?
  description    String?        @db.Text
  description_en String?        @db.Text
  description_zh String?        @db.Text
  description_ar String?        @db.Text
  audience       SurveyAudience @default(BOTH_VIP)
  status         SurveyStatus   @default(DRAFT)
  questions      Json // mảng câu hỏi (xem comment trên)
  questions_en   Json? // translated questions array (same structure, labels in English)
  questions_zh   Json? // translated questions array (same structure, labels in Chinese)
  questions_ar   Json? // translated questions array (same structure, labels in Arabic)
  config         Json? // { scoring: {...}, recommendation: {...} } — tùy loại survey
  startsAt       DateTime?
  endsAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses SurveyResponse[]

  @@index([status, audience])
  @@map("surveys")
}

/**
 * Phản hồi khảo sát — cho phép cả user đã đăng nhập và khách public.
 * - userId: set nếu người trả lời là member đã login (giữ mirror mapsTo)
 * - contact*: thông tin user tự điền (bắt buộc với public submissions)
 * - submitterType: "INDIVIDUAL" | "BUSINESS" — user tự chọn ở step đầu
 */
model SurveyResponse {
  id       String  @id @default(cuid())
  surveyId String
  userId   String?

  // Contact info (do user tự điền, bắt buộc cho anon)
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  avatarUrl     String? // ảnh đại diện cá nhân (cho INDIVIDUAL)
  companyName   String?
  logoUrl       String?
  submitterType String? // "INDIVIDUAL" | "BUSINESS"

  answers         Json
  score           Int?
  recommendedTier String?
  submittedAt     DateTime @default(now())

  // IP để dedupe / rate-limit theo request (tùy chọn lưu)
  submitterIp String?

  survey Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([surveyId, submittedAt])
  @@index([userId])
  @@index([contactEmail])
  @@map("survey_responses")
}

/**
 * Yêu cầu tư vấn nâng cấp — phát sinh từ CTA cuối flow khảo sát.
 * Giai đoạn này chưa có flow thanh toán nâng cấp tự động → chỉ ghi nhận
 * để admin liên hệ lại.
 */
model ConsultationRequest {
  id              String             @id @default(cuid())
  userId          String? // null nếu anon (từ /khao-sat public)
  fullName        String
  phone           String
  email           String?
  companyName     String?
  note            String?            @db.Text
  context         String? // "survey:member-onboarding" — nguồn phát sinh
  recommendedTier String?
  status          ConsultationStatus @default(PENDING)
  handledById     String?
  handledAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user      User? @relation("ConsultationRequester", fields: [userId], references: [id], onDelete: SetNull)
  handledBy User? @relation("ConsultationHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId])
  @@map("consultation_requests")
}

// ============================================================
// CONTACT MESSAGES — form liên hệ công khai (/lien-he)
// ============================================================
// Guest / anon gửi qua form ở footer & trang /lien-he. Lưu DB trước
// rồi gửi email notify → admin thấy lại trong /admin/lien-he và
// notification bell kể cả khi email bị lọc / inbox chung bị bỏ sót.

enum ContactStatus {
  NEW // vừa gửi, chờ admin đọc
  HANDLED // admin đã liên hệ lại / xử lý xong
  ARCHIVED // lưu trữ, không cần xử lý (spam, trùng...)
}

model ContactMessage {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String?
  message     String        @db.Text
  status      ContactStatus @default(NEW)
  handledAt   DateTime?
  handledById String?
  adminNote   String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  handledBy User? @relation("ContactHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("contact_messages")
}

// ============================================================
// LEDGER — Sổ quỹ thu chi của Hội (admin only)
// ============================================================
//
// Single-account ledger: hội dùng 1 tài khoản duy nhất → số dư =
// SUM(income) - SUM(expense). Số dư đầu kỳ là 1 transaction system
// (category isSystem=true) nhập 1 lần qua wizard.
//
// amount: BigInt nguyên đồng VND (không phần lẻ). Khi serialize qua
// Server → Client phải Number(amount) — VND không vượt 2^53.

enum LedgerType {
  INCOME // Thu
  EXPENSE // Chi
}

enum LedgerPaymentMethod {
  CASH // Tiền mặt
  BANK // Chuyển khoản ngân hàng
}

model LedgerCategory {
  id           String     @id @default(cuid())
  name         String
  type         LedgerType
  parentId     String?
  displayOrder Int        @default(0)
  isActive     Boolean    @default(true)
  // Danh mục hệ thống (Số dư đầu kỳ, các danh mục map từ PaymentType) —
  // không cho xóa qua UI thường, vẫn cho rename.
  isSystem     Boolean    @default(false)

  parent       LedgerCategory?     @relation("LedgerCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     LedgerCategory[]    @relation("LedgerCategoryHierarchy")
  transactions LedgerTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, displayOrder])
  @@index([parentId])
  @@map("ledger_categories")
}

model LedgerTransaction {
  id              String              @id @default(cuid())
  type            LedgerType
  categoryId      String
  amount          BigInt // VND nguyên đồng — luôn dương; type quyết định +/-
  transactionDate DateTime            @db.Date
  paymentMethod   LedgerPaymentMethod @default(BANK)
  referenceNo     String? // số phiếu thu/chi, mã GD ngân hàng
  description     String              @db.Text
  receiptUrl      String? // ảnh chứng từ — Cloudinary thu-chi/{MM-YYYY}/

  // Liên kết tới Payment khi auto-tạo từ flow xác nhận CK; null khi nhập tay.
  // 1 Payment chỉ sinh 1 LedgerTransaction (avoid double counting).
  relatedPaymentId String? @unique

  // System transaction = "Số dư đầu kỳ" — không cho xóa, cho phép edit.
  isSystem Boolean @default(false)

  recordedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   LedgerCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  recordedBy User           @relation("LedgerTransactionRecorder", fields: [recordedById], references: [id])
  payment    Payment?       @relation(fields: [relatedPaymentId], references: [id], onDelete: SetNull)

  @@index([type, transactionDate])
  @@index([categoryId])
  @@index([transactionDate])
  @@index([recordedById])
  @@map("ledger_transactions")
}

// ============================================================
// STATIC PAGE CONFIG — Cấu hình text cho các trang tĩnh
// ============================================================

model StaticPageConfig {
  id        String   @id @default(cuid())
  pageKey   String   // "about", "contact", "home", ...
  itemKey   String   // "heroTitle", "heroDesc", ...
  value     String   @db.Text
  value_en  String?  @db.Text
  value_zh  String?  @db.Text
  value_ar  String?  @db.Text
  updatedAt DateTime @updatedAt

  @@unique([pageKey, itemKey])
  @@map("static_page_configs")
}

// ============================================================
// SERVICE QUOTA MONITORING — theo dõi free-tier usage
// ============================================================

/// Snapshot dùng dung lượng / requests / bandwidth của các service bên ngoài
/// (Cloudinary, Google Drive, Supabase, Vercel). Cron daily ghi 1 row mỗi
/// metric. Dashboard /admin/giam-sat đọc latest snapshot + trend 30 ngày.
///
/// Vercel free tier không có Usage API → admin nhập tay (source=MANUAL).
/// Còn lại đọc tự động qua API (source=AUTO) — Cloudinary `/usage`,
/// Drive `about.get`, Supabase `pg_database_size()`.
model ServiceQuotaSnapshot {
  id          String              @id @default(cuid())
  service     ServiceQuotaService // CLOUDINARY | GDRIVE | SUPABASE | VERCEL
  metric      String              // vd "storage_bytes", "monthly_bandwidth", "transformations", "db_size_bytes"
  used        BigInt              // số lượng dùng (đơn vị tuỳ unit)
  limit       BigInt              // ngưỡng free tier
  unit        String              // "bytes", "count", "ms" — chỉ để render
  source      ServiceQuotaSource  @default(AUTO)
  note        String?             @db.Text // chi tiết thêm (lỗi fetch, manual entry note)
  capturedAt  DateTime            @default(now())

  @@index([service, metric, capturedAt])
  @@index([capturedAt])
  @@map("service_quota_snapshots")
}

enum ServiceQuotaService {
  CLOUDINARY
  GDRIVE
  SUPABASE
  VERCEL
}

enum ServiceQuotaSource {
  AUTO   // fetch tự động qua API
  MANUAL // admin nhập tay (cho service không có public API free-tier)
}
